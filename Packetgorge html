  <script>
    // ===== ANIMATED BACKGROUND (Canvas) =====
    (function() {
      const canvas = document.getElementById('bg-canvas');
      const ctx = canvas.getContext('2d');
      let w, h;

      function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // Binary rain & grid
      const chars = '01';
      const fontSize = 16;
      let columns = Math.floor(w / fontSize);
      let drops = new Array(columns).fill(1);

      function draw() {
        ctx.fillStyle = 'rgba(7, 11, 24, 0.06)';
        ctx.fillRect(0, 0, w, h);

        ctx.fillStyle = '#00E5FF';
        ctx.font = fontSize + 'px monospace';
        ctx.shadowBlur = 6;
        ctx.shadowColor = '#00E5FF33';

        for (let i = 0; i < drops.length; i++) {
          const text = chars[Math.floor(Math.random() * chars.length)];
          ctx.fillText(text, i * fontSize, drops[i] * fontSize);

          if (drops[i] * fontSize > h && Math.random() > 0.975) {
            drops[i] = 0;
          }
          drops[i]++;
        }

        // Draw grid lines (subtle)
        ctx.strokeStyle = 'rgba(0, 229, 255, 0.02)';
        ctx.lineWidth = 0.5;
        for (let x = 0; x < w; x += 40) {
          ctx.beginPath();
          ctx.moveTo(x, 0);
          ctx.lineTo(x, h);
          ctx.stroke();
        }
        for (let y = 0; y < h; y += 40) {
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(w, y);
          ctx.stroke();
        }

        requestAnimationFrame(draw);
      }
      draw();
    })();

    // ===== FLOATING PACKETS =====
    (function() {
      const container = document.getElementById('floatingPackets');
      const hexValues = ['0x45', '0x00', '0x3c', '0x1a', '0x2b', '0x40', '0x06', '0x6f', '0x8c', '0xc0', '0xa8', '0x01', '0x0a'];
      for (let i = 0; i < 25; i++) {
        const el = document.createElement('div');
        el.className = 'packet';
        el.textContent = hexValues[Math.floor(Math.random() * hexValues.length)];
        el.style.left = Math.random() * 90 + '%';
        el.style.animationDuration = (18 + Math.random() * 20) + 's';
        el.style.animationDelay = (Math.random() * 15) + 's';
        el.style.fontSize = (0.7 + Math.random() * 0.6) + 'rem';
        container.appendChild(el);
      }
    })();

    // ===== PACKET BUILDER =====
    const buildBtn = document.getElementById('buildPacket');
    const protocolSelect = document.getElementById('protocol');
    const destIP = document.getElementById('destIP');
    const portInput = document.getElementById('port');
    const flagsSelect = document.getElementById('flags');
    const flagDisplay = document.getElementById('flagDisplay');
    const protoDisplay = document.getElementById('protoDisplay');
    const previewDiv = document.getElementById('packetPreview');

    function updatePacketPreview() {
      const proto = protocolSelect.value;
      const ip = destIP.value || '192.168.1.10';
      const port = portInput.value || '443';
      const flags = flagsSelect.value;

      flagDisplay.textContent = flags;
      protoDisplay.textContent = proto;

      // Build random hex lines (demo)
      const lines = [
        { offset: '0000', hex: '45 00 00 3c 1a 2b 40 00 40 06 6f 8c ' + ip.split('.').map(n => ('0' + parseInt(n).toString(16)).slice(-2)).join(' '), ascii: 'E..<.+@.@.o....' },
        { offset: '0010', hex: 'c0 a8 01 01 00 ' + ('0' + parseInt(port).toString(16)).slice(-2) + ' 01 bb 00 00 00 00 00 00 00 00', ascii: '.....P..........' },
        { offset: '0020', hex: '50 10 01 00 00 00 00 00 00 00 00 00 00 00 00 00', ascii: 'P...............' }
      ];

      // Apply different colors for protocol
      let highlightClass = 'highlight';
      if (proto === 'UDP') highlightClass = 'highlight-udp';
      else if (proto === 'ICMP') highlightClass = 'highlight-icmp';

      // Rebuild preview
      let html = '';
      lines.forEach((line, idx) => {
        const cls = idx === 2 ? 'hex ' + highlightClass : 'hex';
        html += `<div class="packet-line"><span class="offset">${line.offset}</span><span class="${cls}">${line.hex}</span><span class="ascii">${line.ascii}</span></div>`;
      });
      html += `<div style="margin-top:12px; color:#7C4DFF; font-size:0.8rem;">⚡ Flags: <span id="flagDisplay">${flags}</span> &nbsp;|&nbsp; Protocol: <span id="protoDisplay">${proto}</span></div>`;
      previewDiv.innerHTML = html;

      // Animate packet movement
      const anim = document.getElementById('packetAnim');
      anim.style.animation = 'none';
      void anim.offsetHeight; // reflow
      anim.style.animation = 'movePacket 2.5s infinite alternate ease-in-out';
    }

    buildBtn.addEventListener('click', updatePacketPreview);

    // Initial update
    updatePacketPreview();

    // ===== DASHBOARD COUNTERS (animated) =====
    (function animateCounters() {
      const totalEl = document.getElementById('totalPackets');
      const tcpEl = document.getElementById('tcpCount');
      const udpEl = document.getElementById('udpCount');

      let total = 1284, tcp = 845, udp = 312;
      setInterval(() => {
        total += Math.floor(Math.random() * 3);
        tcp += Math.floor(Math.random() * 2);
        udp += Math.floor(Math.random() * 2);
        totalEl.textContent = total.toLocaleString();
        tcpEl.textContent = tcp.toLocaleString();
        udpEl.textContent = udp.toLocaleString();
      }, 3000);
    })();

    // ===== FAQ TOGGLE =====
    window.toggleFAQ = function(el) {
      const parent = el.parentElement;
      parent.classList.toggle('active');
    };
  </script>
